# LiveScan release installer configuration
# Copy to scripts/release_installer.env and customize.

# Python interpreter used to create the virtual environment.
PYTHON_BIN=python3

# Absolute or relative path for virtual environment.
VENV_DIR=.venv

# editable | release
INSTALL_MODE=editable

# Optional extras when INSTALL_MODE=editable.
EXTRAS=dev

# true | false
UPGRADE_PIP=true

# true | false
START_API=false

HOST=0.0.0.0
PORT=8000
